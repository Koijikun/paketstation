# PostgreSQL / PostGIS Verbindung
# Kopiere diese Datei nach ".env" und passe die Werte an.
# Die .env-Datei ist in .gitignore und wird NICHT eingecheckt.

PG_HOST=localhost
PG_PORT=5432
PG_DB=paketstation
PG_USER=postgres
PG_PASSWORD=

# Optional: erlaubte CORS-Origins (kommagetrennt).
# Default deckt die lokal ausgelieferte Karte ab; nur anpassen, wenn die API
# von einem anderen Origin aus aufgerufen wird.
# CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
